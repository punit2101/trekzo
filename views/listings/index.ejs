<div class="max-w-7xl mx-auto px-6 py-8">

  <h1 class="text-3xl font-bold mb-8">All Listings</h1>

  <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">

    <% for(let listing of allListings){ %>

      <a href="/listings/<%= listing._id %>">

        <div
          class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl hover:-translate-y-1 transition duration-300"
        >

          <img
            src="<%= listing.image %>"
            alt="<%= listing.title %>"
            class="w-full h-64 object-cover"
          />

          <div class="p-4">

            <h2 class="text-lg font-semibold truncate">
              <%= listing.title %>
            </h2>

            <p class="text-gray-500 mt-1">
              <%= listing.location %>, <%= listing.country %>
            </p>

            <p class="mt-3 text-lg font-bold">
              ₹<%= listing.price.toLocaleString("en-IN") %>
              <span class="text-sm font-normal text-gray-500">/ night</span>
            </p>

          </div>

        </div>

      </a>

    <% } %>

  </div>

</div>
</body>