<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Index Route</title>
</head>

<body>
  <h3>All Listings</h3>
  <ul>
    <% for(let listing of allListings){ %>
      <li>
        <a href="/listings/<%= listing._id %>">
          <%= listing.title %>
        </a>
        <a href=""><%= listing.image %></a>
      </li>
      <% } %>
  </ul>

</body>

</html>